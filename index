<!DOCTYPE html>
<html>
<head><title>MDL Player</title></head>
<body>
  <script>
    const params = new URLSearchParams(window.location.search);
    const linkFilme = params.get('url');
    if (linkFilme) {
      window.location.href = linkFilme;
    } else {
      document.write("Ponte MDL ativa. Use ?url=link_do_video");
    }
  </script>
</body>
</html>
